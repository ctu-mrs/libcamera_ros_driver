/// Based on /opt/ros/jazzy/share/rmw_zenoh_cpp/config/DEFAULT_RMW_ZENOH_ROUTER_CONFIG.json5

/// This configuration controls the ROS2 traffic between multiple hosts.
/// Inter-host traffic between the nodes of an individual host is specified by session config and "should" not be influenced by the settings, however, results may vary and it is discouraged to for example change the node from the "router" mode.
/// Refer to the original file above for in-detail explanation and treat the following comments as a field-guide.

///
/// ----------- READ BEFORE USE ----------- 
///
/// Configure the router for specific UAV type and/or your PC by re-placing the value "wlp2s0" with the full name of the wi-fi interface on the machine the config file is used on. Use "bash ifconfig" to find out.
/// On PC or "main" UAV, specify end-points as IP addresses/hostnames of the other machines to be networked. Always include the interface.
///

{
  /// WARNING: this id must be unique in your zenoh network. By default, it is assigned by random.
  // id: "1234567890abcdef",

  /// The node's mode (router, peer or client). Do not change.
  mode: "router",

  connect: {
    /// timeout waiting for all endpoints connected (0: no retry, -1: infinite timeout)
    timeout_ms: { router: -1, peer: -1, client: 0 },

    /// Configure IP addresses or hostnames of the other connected machines and include the local network interface.
    endpoints: [
      "tcp/10.10.20.22:7447#eth0",
      // "tcp/uav30:7447#wlp2s0",
    ],

    /// exit from application, if timeout exceed
    exit_on_failure: { router: false, peer: false, client: true },
    /// connect establishing retry configuration
    retry: {
      /// initial wait timeout until next connect try
      period_init_ms: 1000,
      /// maximum wait timeout until next connect try
      period_max_ms: 4000,
      /// increase factor for the next timeout until nexti connect try
      period_increase_factor: 2,
    },
  },

  /// Which endpoints to listen on. E.g. tcp/0.0.0.0:7447.
  listen: {
    /// timeout waiting for all listen endpoints (0: no retry, -1: infinite timeout)
    timeout_ms: 0,

    endpoints: [
      "tcp/[::]:7447#eth0"
    ],

    /// exit from application, if timeout exceed
    exit_on_failure: true,
    /// listen retry configuration
    retry: {
      /// initial wait timeout until next try
      period_init_ms: 1000,
      /// maximum wait timeout until next try
      period_max_ms: 4000,
      /// increase factor for the next timeout until next try
      period_increase_factor: 2,
    },
  },

  /// Configure internal transport parameters
  transport: {
    link: {
      /// Configure the zenoh TX parameters of a link
      tx: {
        /// Link lease duration in milliseconds to announce to other zenoh nodes
        lease: 10000,
        /// Number of keep-alive messages in a link lease duration. If no data is sent, keep alive
        keep_alive: 4,
        /// Each zenoh link has a transmission queue that can be configured
        queue: {
          /// Congestion occurs when the queue is empty (no available batch).
          congestion_control: {
            /// Behavior pushing CongestionControl::Drop messages to the queue.
            drop: {
              /// The maximum time in microseconds to wait for an available batch before dropping a droppable message if still no batch is available.
              wait_before_drop: 1000000,
              /// The maximum deadline limit for multi-fragment messages.
              max_wait_before_drop_fragments: 50000,
            },       
          },
        },
      },
    },
  },

  /// Downsampling throttles how frequently a topic can flow in (ingress) and out (egress) of the host over the network.
  /// This is critical for camera topics: at 1280x800 RGB888 @ 60 Hz, each camera generates ~184 MB/s.
  /// Streaming both cameras at full rate over Wi-Fi WILL saturate the link instantly.
  ///
  /// IMPORTANT — Zenoh key expression rules for wildcards:
  ///   * and ** must each occupy a complete /.../ chunk on their own.
  ///   They CANNOT be mixed with literal text in the same chunk (e.g. "rpi_camera_*" is INVALID).
  ///   Valid: **/image_raw  |  Invalid: **/rpi_camera_*/**  |  Invalid: **/rpi_camera_**
  ///
  /// We therefore match on the leaf topic names (image_raw, camera_info) which are chunk-isolated.

  downsampling: [

    /// --- RealSense RGBD throttle (kept as reference example) ---
    //  {
    //    id: "realsense_throttle",
    //    interfaces : ["wlp2s0"],
    //    messages: ["delete", "put", "query", "reply"],
    //    rules: [
    //      { key_expr: "**/rgbd/**", freq: 1.0 },
    //    ],
    //  },

    /// --- RPI camera image throttle ---
    /// Applies to all image_raw and camera_info topics on any UAV/camera namespace.
    /// Tune freq to your bandwidth budget:
    ///   5.0  Hz -> low-bandwidth situational awareness (recommended default over Wi-Fi)
    ///   10.0 Hz -> moderate bandwidth, usable for visual inspection
    ///   30.0 Hz -> only viable on a dedicated high-throughput link (5GHz / Ethernet)
    {
      "id": "rpi_camera_throttle",

      /// Apply only to off-host network interfaces.
      /// Change to match your UAV's actual interface name (check with: ip a).
      "interfaces": ["wlan0", "eth0"],

      "messages": [
        "put",
        "delete",
        "query",
        "reply",
      ],

      "rules": [
        {
          /// Matches: uav1/rpi_camera_front/image_raw, uav1/rpi_camera_back/image_raw, etc.
          /// Valid because "image_raw" is a standalone chunk after **/
          "key_expr": "**/image_raw",
          "freq": 5.0,   /// [Hz]
        },
        {
          /// Throttle camera_info to same rate to keep it paired with image frames.
          "key_expr": "**/camera_info",
          "freq": 5.0,   /// [Hz]
        },
      ],
    },
  ],


  /// Zenoh Access Control enables specifying which data can flow in/out the host based on rules.
  /// See "https://zenoh.io/docs/manual/access-control/" for thorough documentation.

  /// Zenoh works on-demand, e.g. a data starts flowing only once a subscriber actively engages with the publisher (on a different host).
  /// However, the "/tf" and "/tf_static" topics are not namespaced so the traffic rules are mandatory unless traffic is denied by default.

  /// We enable the ACL ("enabled" : true) but allow all traffic by default ("default_permission": "allow").
  access_control: {
    "enabled": true,
    "default_permission": "allow",

  /// Here we specify the ROS2 message types, flows, and multiple possible key expressions which the rule will apply to.
    "rules": [
      {
        "id": "deny_non_namespaced_over_network",
        "messages": ["put", "delete", "declare_subscriber", "query", "reply","declare_queryable", "liveliness_token", "liveliness_query", "declare_liveliness_subscriber"],        
        "flows": ["egress","ingress"],
        "permission": "deny",
        "key_exprs": [
          "**/tf/**",
          "**/tf",
          "**/tf_static/**",
          "**/tf_static",
          "**/uas1/**",
        ]
      },

      /// Blocks RealSense/RGBD traffic over the network.
      /// rpi_camera topics are intentionally NOT listed here — they are allowed
      /// through and rate-limited only by the downsampling rule above.
      {
        "id": "deny_realsense_over_network",
        "messages": [
          "put", "delete",
          "declare_subscriber", "declare_queryable",
          "query", "reply",
          "liveliness_token", "liveliness_query",
          "declare_liveliness_subscriber"
        ],
        "flows": ["egress","ingress"],
        "permission": "deny",
        "key_exprs": [
          "**/rgbd/**",
        ]
      },

      /// --- OPTIONAL: explicit allow rule for rpi_camera topics ---
      /// Not needed with default_permission "allow".
      /// Uncomment ONLY if you switch default_permission to "deny" for a strict allow-list posture.
      // {
      //   "id": "allow_rpi_camera_over_network",
      //   "messages": [
      //     "put", "delete",
      //     "declare_subscriber", "declare_queryable",
      //     "query", "reply",
      //     "liveliness_token", "liveliness_query",
      //     "declare_liveliness_subscriber"
      //   ],
      //   "flows": ["egress", "ingress"],
      //   "permission": "allow",
      //   "key_exprs": [
      //     "**/image_raw",
      //     "**/camera_info",
      //   ]
      // },

    ],

    /// Subjects specify interfaces to which the ACL rules are applied.
    "subjects": [
      {
        "id": "local_loopback",
        "interfaces": ["lo", "lo0"]
      },
      {
        "id": "wifi_interfaces",
        "interfaces": ["wlan0", "eth0"]
      }
    ],

    /// Policies assign rules to the subjects.
    "policies": [
      {
        "id": "block_non_namespaced",
        "rules": ["deny_non_namespaced_over_network"],
        "subjects": ["wifi_interfaces", "local_loopback"]
      },
      {
        "id": "wifi_block_realsense",
        "rules": ["deny_realsense_over_network"],
        "subjects": ["wifi_interfaces"]
      },

      /// --- OPTIONAL: uncomment if using strict deny-by-default posture ---
      // {
      //   "id": "wifi_allow_rpi_camera",
      //   "rules": ["allow_rpi_camera_over_network"],
      //   "subjects": ["wifi_interfaces"]
      // },
    ]
  },

  /// The QOS override is required so the network stack does not clog up with the un-droppable "/tf_static" messages set as "reliable" because of the ACL rules above.
  qos: {
    /// Overwrite QoS options for PUT and DELETE messages
    publication: [
      {
        /// PUT and DELETE messages on key expressions that are included by these key expressions
        /// will have their QoS options overwritten by the given config.
        key_exprs: ["**"], /// that's all traffic
        /// Configurations that will be applied on the publisher.
        /// Options that are supplied here will overwrite the configuration given in Zenoh API
        config: {
          congestion_control: "drop",
          priority: "data_low",
          express: true,
          reliability: "best_effort",
          allowed_destination: "remote",
        },
      },
    ],
  },

}
